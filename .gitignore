# Node
node_modules/

# VS Code extension build artifact (build lai qua vsce package, khong commit binary)
*.vsix

# Python
__pycache__/
*.py[cod]
*.pyc
build/
dist/
*.egg-info/

# Logs
*.log

# Tests
test-results/
test/
tests/
!tests/README.md
!reference/mcp-server/tests/
!hooks/hook_tests/

# Temp scripts
_*.py
!__init__.py


# Sync skills daemon runtime state (per-machine; *.log da duoc rule rieng o tren)
.sap-abap-agent/sync_skills.lock

# Personal learning progress (state rieng cua tung user, khong track)
.sap-abap-agent/LEARNING_PROGRESS.md
skills/sap-user-skills/*
!skills/sap-user-skills/README.md

# Session handoff / scaffold working state (ca nhan, khong track)
.sap-abap-agent/sessions/
.sap-abap-agent/handoff/

# Dev mirror cua sap-btp-agent profiles (chi khi dev bat SAP_BTP_AGENT_DEV_MIRROR)
.sap-abap-agent/dev-mirror/

# sap-daily-learner: memory 3 tang (episodic/semantic/procedural - ca nhan, khong track)
.sap-abap-agent/memory/

# sap-context-tool-result-trim (reference/process/): cache full output truoc khi mask (ca nhan, khong track)
.sap-abap-agent/cache/

# Env / secrets (duoc ma hoa nhung can than)
.env
.env.local
mcp-abap-adt-*.env

# Other
in/
out/

# Local Claude Code settings (per-machine hooks/permissions) - phai o day, khong chi dua vao
# personal git excludesFile cua tung may (may/CI khac se khong tu chan)
.claude/settings.local.json

# VS Code workspace settings (per-machine, khong track)
.vscode/
!/.vscode/extensions.json  # neu co file nay trong repo thi track

# Du lieu du an/khach hang that dung lam fixture cuc bo khi dev (KHONG BAO GIO track) - rule
# rieng, khong chi dua vao dong "tests/" chung o tren (repo da co tien le track file trong
# tests/ nen dong do khong con la rao chan chac chan)
tests/__Du_an/
tests/src/
!tests/README.md
!tests/__Du_an/README.md

# docs/sap-knowledge/: cac index/catalog SINH TU codebase THAT cua khach hang (khong phai
# chi "nhac ten" - doi ten label khong du de an danh vi noi dung ben trong van la object/field/
# path THAT). Cac file .md con lai trong docs/sap-knowledge/ da duoc doi ten/an danh, giu lai binh
# thuong. Xem chi tiet quyet dinh trong PR/trao doi voi Claude.

# Build artifacts generated by sync-index workflow (do not commit)
/index.head.tmp
/index.tail.tmp
/translations.tmp
