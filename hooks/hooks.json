{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"${CLAUDE_PLUGIN_ROOT}/skills/sap-routing-discipline/SKILL.md\"; [ -f \"$f\" ] || exit 0; sed -n '/^---$/,/^---$/!p' \"$f\" | python -c \"import sys, json; print(json.dumps({'hookSpecificOutput': {'hookEventName': 'SessionStart', 'additionalContext': sys.stdin.read()}}))\"",
            "async": false
          },
          {
            "type": "command",
            "command": "f=\"${CLAUDE_PLUGIN_ROOT}/skills/sap-ask-before-guessing/SKILL.md\"; [ -f \"$f\" ] || exit 0; sed -n '/^---$/,/^---$/!p' \"$f\" | python -c \"import sys, json; print(json.dumps({'hookSpecificOutput': {'hookEventName': 'SessionStart', 'additionalContext': sys.stdin.read()}}))\"",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/zy_namespace_guard.py\"",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(python -c \"import sys, json; print(json.load(sys.stdin).get('tool_input', {}).get('file_path', '') or '')\"); if [ -n \"$file\" ] && [[ \"$file\" == *.abap ]] && grep -nE 'SELECT[[:space:]]+\\*' \"$file\" >/dev/null 2>&1; then echo \"[sap-abap-agent] SELECT * found in $file - prefer explicit field lists.\" >&2; fi; exit 0"
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/verify_nudge.py\" mark-edit"
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/error_reporter.py\" detect-tool"
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/error_reporter.py\" detect-fix"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/verify_nudge.py\" mark-verified"
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/error_reporter.py\" detect-bash"
          }
        ]
      },
      {
        "matcher": "sap_",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/error_reporter.py\" detect-tool"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/verify_nudge.py\" check-stop",
            "async": false
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/error_reporter.py\" report",
            "async": true
          }
        ]
      }
    ]
  }
}
