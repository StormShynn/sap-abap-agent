# EditorConfig (https://editorconfig.org) giup moi contributor giu indent/EOL
# consistent khi edit file trong repo nay.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4

[*.md]
indent_size = 2

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.abap]
indent_size = 2

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf

[*.ps1]
end_of_line = crlf
